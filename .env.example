# TAPFORGE Telegram Bot config
# 1) НЕ вставляй сюди старий токен, якщо ти вже показав його комусь.
# 2) У BotFather зроби /revoke і отримай новий токен.
BOT_TOKEN=PASTE_NEW_BOT_TOKEN_HERE

# Username бота без @
BOT_USERNAME=tapforge_bot

# HTTPS адреса, яку відкриває кнопка Play TAPFORGE.
# Для Telegram Mini App потрібен HTTPS, localhost у реальному Telegram не підійде.
WEBAPP_URL=https://your-domain.com

PORT=3000
